[sqlfluff]
# Dialeto do nosso banco (DuckDB)
dialect = duckdb
# Mudamos de 'dbt' para 'jinja' para passar no CI sem precisar do plugin pesado
templater = jinja
# Ignorar arquivos compilados ou temporários
exclude_rules = L031
max_line_length = 120

[sqlfluff:templater:jinja]
apply_dbt_builtins = True

# Ignora pastas de cache do dbt
[sqlfluff:directories]
exclude_dirs = olist_analytics/dbt_packages, olist_analytics/target