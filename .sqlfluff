[sqlfluff]
dialect = duckdb
templater = dbt
run_away_limit = 10
max_line_length = 120
indent_unit = space
# Ignora arquivos compilados ou temporários
exclude_rules = L031

[sqlfluff:indentation]
tab_space_size = 4

[sqlfluff:rules]
allow_scalar = True

# [CORREÇÃO] Configuração do dbt Templater
# Diz ao SQLFluff onde encontrar o dbt_project.yml e o profiles.yml
[sqlfluff:templater:dbt]
project_dir = olist_analytics
profiles_dir = olist_analytics
target = dev